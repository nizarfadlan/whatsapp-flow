{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.4.0",
		"@whatsapp-flow/api": "workspace:*",
		"@whatsapp-flow/auth": "workspace:*",
		"@whatsapp-flow/db": "workspace:*",
		"@whatsapp-flow/env": "workspace:*",
		"@whatsapp-flow/whatsapp": "workspace:*",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"hono": "catalog:",
		"zod": "catalog:",
		"@whatsapp-flow/storage": "workspace:*"
	},
	"devDependencies": {
		"@whatsapp-flow/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.21.9",
		"typescript": "catalog:"
	}
}
