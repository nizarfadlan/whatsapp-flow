# Copy this file to .env.docker before running Docker commands.
# Generate secrets with: openssl rand -base64 32

NODE_ENV=production
SERVER_PORT=3000
WEB_PORT=3001
DATABASE_URL=postgres://postgres:password@postgres:5432/whatsapp-flow
AUTH_SECRET=replace-with-at-least-32-characters
AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
# Set false only for trusted plain-HTTP deployments on one host/IP; omit or set true for HTTPS.
AUTH_USE_SECURE_COOKIES=false
SETTINGS_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

VITE_SERVER_URL=http://localhost:3000

STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=/app/uploads
# Set to false to keep inbound WhatsApp media metadata only.
INBOUND_MEDIA_AUTO_DOWNLOAD=true

ADMIN_EMAILS=
PUBLIC_BASE_URL=http://localhost:3001
METRICS_TOKEN=

META_GRAPH_API_VERSION=v23.0
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_ID=
META_EMBEDDED_SIGNUP_CONFIG_ID=
VITE_META_APP_ID=
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
